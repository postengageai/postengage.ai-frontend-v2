# PostEngage.ai Frontend — required environment variables
# Copy this file to .env.local and fill in the values for your environment.
# Never commit .env.local to version control.

# ── API ─────────────────────────────────────────────────────────────────────
# Base URL of the gatekeeper backend API
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── WebSocket / Realtime ────────────────────────────────────────────────────
# URL of the pulse (Socket.IO) server for real-time notifications and activity
NEXT_PUBLIC_SOCKET_URL=http://localhost:3002

# ── Analytics (optional) ────────────────────────────────────────────────────
# PostHog project API key — leave blank to disable analytics in development
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
